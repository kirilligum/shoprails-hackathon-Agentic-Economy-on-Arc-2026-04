GEMINI_API_KEY=

# The product demo uses live Gemini by default. Tests can still instantiate the deterministic provider in code.
SHOPRAILS_LLM_PROVIDER=gemini
SHOPRAILS_IMAGE_PROVIDER=gemini

# Official current Gemini model names are configurable because preview aliases move.
SHOPRAILS_TEXT_MODEL=gemini-3.1-flash-lite-preview
SHOPRAILS_TEXT_FALLBACK_MODEL=gemini-3-flash-preview
SHOPRAILS_IMAGE_MODEL=gemini-3.1-flash-image-preview
SHOPRAILS_FAST_IMAGE_MODEL=gemini-2.5-flash-image

CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID=
CIRCLE_WALLET_ADDRESS=
CIRCLE_WALLET_BLOCKCHAIN=ARC-TESTNET
